# Copy to .env.local before running locally

NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
RYNXPENSE_EDGE_SECRET="shared-secret-for-edge-function"
NEXT_PUBLIC_APP_PROJECT_SLUG="rynxpense-dev"
# Local dev: direct Groq calls (optional — edge function is preferred in production)
RYNXPENSE_GROQ_API_KEY="your-groq-api-key"
# Do NOT set GROQ_API_KEY on Vercel — a stale legacy key causes 401 errors.
# Production: Groq key lives in Supabase secret RYNXPENSE_GROQ_API_KEY; Next.js invokes
# rynxpense-generate-trip edge function via SUPABASE_SERVICE_ROLE_KEY.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
